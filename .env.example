# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SIGNING_SECRET=your_clerk_webhook_signing_secret
CLERK_SIGNUP_DISCORD_CHANNEL_ID=1505933125954306099

# Discord Support
DISCORD_BOT_TOKEN=your_discord_bot_token
SUPPORT_OWNER_DISCORD_USER_ID=1387255717794152519
SUPPORT_DISCORD_GUILD_ID=your_support_guild_id
SUPPORT_DISCORD_INVITE_URL=https://discord.gg/your-invite
SUPPORT_JOINED_ROLE_ID=1503653833199583353
SUPPORT_TERMS_ROLE_ID=1505506067499454505
SUPPORT_PRIVACY_ROLE_ID=1505505950881026158
SUPPORT_VERIFIED_ROLE_ID=1394049709877891099
RULES_REACTION_MESSAGE_ID=1505946455154757775
RULES_REACTION_EMOJI_ID=1505929819903492297
RULES_REACTION_EMOJI_NAME=hayashilogo

# Stripe Billing
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# Stripe billing identifiers
# Prefer Stripe `price_...` ids here. `prod_...` product ids are also accepted,
# but the server then has to resolve the product's default/active price first.
STRIPE_PRICE_CREATOR=price_your_creator_price_id
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_STUDIO=price_your_studio_price_id

# Server
SERVER_PORT=3001
CLIENT_URL=http://localhost:5173

# Cloudflare Workers AI (for LLM generation)
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
CF_MODEL=@cf/moonshotai/kimi-k2.6

# Optional: use any OpenAI-compatible inference provider instead of Cloudflare
# If AI_BASE_URL / AI_API_KEY / AI_MODEL are set, the server will prefer this path.
# Examples:
# AI_BASE_URL=https://your-endpoint/v1
# AI_API_KEY=your_api_key
# AI_MODEL=your_model_or_deployment_name
# AI_API_KEY_HEADER=Authorization
# AI_API_KEY_PREFIX=Bearer 
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_API_KEY_HEADER=Authorization
AI_API_KEY_PREFIX=Bearer 

# Tigris/S3 Storage (for asset uploads)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=auto
AWS_ENDPOINT_URL_S3=https://your_tigris_endpoint
BUCKET_NAME=your_bucket_name

# Database
DATABASE_URL=postgresql://user:pass@host/db

# Temporal Cloud
# Namespace should be your full namespace slug from Temporal Cloud.
TEMPORAL_NAMESPACE=
TEMPORAL_API_KEY=
# Optional override. Defaults to ${TEMPORAL_NAMESPACE}.tmprl.cloud:7233
TEMPORAL_HOST=

# GitHub Actions native export dispatch
GITHUB_ACTIONS_BUILDS_TOKEN=
GITHUB_ACTIONS_BUILDS_REPO=
GITHUB_ACTIONS_BUILDS_WORKFLOW=plugin-native-build.yml
GITHUB_ACTIONS_BUILDS_ENVIRONMENT=dev
GITHUB_ACTIONS_BUILDS_SERVER_URL=
HAYASHI_BUILD_RUNNER_SECRET=

# Optional: local file-based billing fallback
BILLING_STORE_PATH=/tmp/hayashi/billing

# Optional: Faust compiler path override
FAUST_INCLUDE_PATH=

# Required for strict server-side audio acceptance/ranking.
# The server will hard-fail generation if these commands are unavailable or return invalid metrics.
FAUST_RENDER_COMMAND=hayashi-faust-render
ESSENTIA_ANALYZE_COMMAND=hayashi-essentia-analyze
FAUST_RENDER_TIMEOUT_MS=30000
ESSENTIA_ANALYZE_TIMEOUT_MS=30000
