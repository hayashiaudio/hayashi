{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Hayashi MIDI Bridge",
  "version": "0.1.0",
  "identifier": "com.hayashi.midi-bridge",
  "build": {
    "beforeDevCommand": "cd .. && npm run dev",
    "beforeBuildCommand": "cd .. && npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Hayashi MIDI Bridge",
        "width": 320,
        "height": 320,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "alwaysOnTop": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "shell": {
      "open": "^https://.*"
    }
  }
}
